{
  "AiSettings": {
    "Provider": "OpenAI",              // 활성화할 AI 제공자 ("OpenAI" | "Google" | "Claude" | "Ollama")
    "ModelName": "gpt-4o",             // 사용할 LLM 모델명
    "Temperature": 0.1,                // 검증의 일관성을 위해 낮게(0.0 ~ 0.2) 설정을 권장합니다.
    "MaxL2Attempts": 2,                // L2 AI 의미론적 교차 검토 실패 시 추가로 재시도할 자가 보완 횟수 (1 이상의 정수 또는 "unlimited" 지정 시 무제한)
    "TimeoutSeconds": 300,             // AI API 호출 시 HttpClient 타임아웃 시간 (초 단위, 기본값: 300)
    "Providers": {
      "OpenAI": {
        "ApiKey": "",                  // OpenAI API 키
        "Endpoint": "https://api.openai.com/v1"
      },
      "Google": {
        "ApiKey": "",                  // Google API 키 (Google AI Studio)
        "Endpoint": "https://generativelanguage.googleapis.com"
      },
      "Claude": {
        "ApiKey": "",                  // Claude API 키 (Claude Console)
        "Endpoint": "https://api.anthropic.com"
      },
      "Ollama": {
        "Endpoint": "http://localhost:11434" // 로컬 Ollama 엔드포인트
      }
    }
  },
  "ValidationSettings": {
    "SpecDirectory": "./output",            // 검증에 활용할 역공학 비즈니스 명세서(*_Spec.md) 저장 디렉터리
    "SourceCodeDirectory": "./src",         // 검증 대상 현대화 구현 소스코드 루트 디렉터리
    "TargetLanguage": "Auto",               // 검증 대상 언어 ("Auto" | "C#" | "Java")
    "OutputDirectory": "./output/validation" // 일치성 논리 Gap 보고서 및 1:1 데이터 정합성 리포트가 저장될 출력 디렉터리
  }
}
